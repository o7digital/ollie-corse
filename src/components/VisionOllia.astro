---
const pillars = [
  {
    title: 'WebApp immersive',
    text: 'Espace public, espace producteurs, partenaires et back-office admin dans une expérience fluide, premium et bilingue.',
    accent: 'from-[#dcc89f]/32 via-white/5 to-transparent',
  },
  {
    title: 'Mobile iOS & Android',
    text: 'Gamification, QR codes, géolocalisation, badges, parcours thématiques et contenus exclusifs sur le territoire corse.',
    accent: 'from-[#5ca6b8]/28 via-white/5 to-transparent',
  },
  {
    title: 'Réservations & paiements',
    text: 'Stripe Connect, Apple Pay, Google Pay, PayPal, Wero et reversements multi-fournisseurs sécurisés.',
    accent: 'from-[#8877af]/24 via-white/5 to-transparent',
  },
]
---

<section id="vision" class="relative px-6 py-24 sm:px-8 lg:px-10 lg:py-32">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_14%_50%,rgba(92,166,184,0.10),transparent_0_25%),radial-gradient(circle_at_88%_16%,rgba(216,194,150,0.10),transparent_0_24%)]"></div>

  <div class="mx-auto max-w-7xl">
    <div class="max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-[#dcc89f]/80">Vision produit</p>
      <h2 class="mt-4 font-['Cormorant_Garamond'] text-4xl leading-none text-white sm:text-5xl lg:text-[3.6rem]">
        Un design institutionnel, touristique et business à la fois
      </h2>
      <p class="mt-6 text-base leading-7 text-white/68 sm:text-lg">
        Le mockup met en avant une image premium, immersive et crédible, capable de parler aux visiteurs, aux producteurs, aux partenaires publics et aux équipes internes.
      </p>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      {pillars.map((pillar) => (
        <article class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.05] p-8 shadow-[0_24px_70px_rgba(2,6,10,0.24)] backdrop-blur-xl">
          <div class={`absolute inset-0 bg-gradient-to-br ${pillar.accent}`}></div>
          <div class="relative">
            <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-[1.4rem] border border-white/10 bg-white/[0.08]">
              <div class="relative h-7 w-7">
                <span class="absolute inset-0 rounded-full bg-white/12"></span>
                <span class="absolute left-1 top-1 h-4 w-4 rounded-full bg-[#dcc89f]/70"></span>
                <span class="absolute bottom-0 right-0 h-3.5 w-3.5 rounded-full bg-[#5ca6b8]/70"></span>
              </div>
            </div>
            <h3 class="font-['Cormorant_Garamond'] text-[2rem] leading-none text-white">{pillar.title}</h3>
            <p class="mt-4 text-sm leading-7 text-white/68 sm:text-base">{pillar.text}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
