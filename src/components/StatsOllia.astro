---
const stats = [
  { value: '24', label: 'semaines projet' },
  { value: '2', label: 'langues natives' },
  { value: '400', label: 'mots-clés SEO' },
  { value: '100%', label: 'pensé multi-acteurs' },
]
---

<section class="px-6 py-8 sm:px-8 lg:px-10">
  <div class="mx-auto grid max-w-7xl gap-5 md:grid-cols-2 xl:grid-cols-4">
    {stats.map((item) => (
      <article class="overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.05] p-7 shadow-[0_24px_70px_rgba(2,6,10,0.24)] backdrop-blur-xl">
        <div class="h-px w-20 bg-gradient-to-r from-transparent via-[#dcc89f] to-transparent"></div>
        <p class="mt-6 font-['Cormorant_Garamond'] text-6xl leading-none text-white">{item.value}</p>
        <p class="mt-3 text-sm uppercase tracking-[0.2em] text-[#dcc89f]/80">{item.label}</p>
      </article>
    ))}
  </div>
</section>
