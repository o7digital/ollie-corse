---
const timeline = [
  { step: '01', phase: 'UX / Architecture', duration: '3 semaines' },
  { step: '02', phase: 'WebApp front + back', duration: '8–10 semaines' },
  { step: '03', phase: 'App mobile', duration: '8 semaines' },
  { step: '04', phase: 'Paiements & intégrations', duration: '3 semaines' },
  { step: '05', phase: 'QA & mise en prod', duration: '2 semaines + 2 jours' },
]
---

<section class="relative overflow-hidden border-y border-white/[0.08] bg-white/[0.03] px-6 py-24 sm:px-8 lg:px-10 lg:py-32">
  <div class="mx-auto max-w-7xl">
    <div class="max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-[#dcc89f]/80">Roadmap</p>
      <h2 class="mt-4 font-['Cormorant_Garamond'] text-4xl leading-none text-white sm:text-5xl lg:text-[3.6rem]">
        Planning lisible pour la présentation client
      </h2>
    </div>

    <div class="mt-14 grid gap-5 xl:grid-cols-5">
      {timeline.map((item) => (
        <article class="overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.05] p-6 shadow-[0_22px_60px_rgba(2,6,10,0.20)] backdrop-blur-xl">
          <div class="inline-flex rounded-full border border-white/10 bg-white/[0.06] px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.22em] text-[#dcc89f]/82">
            {item.step}
          </div>
          <p class="mt-8 font-['Cormorant_Garamond'] text-3xl leading-none text-white">{item.phase}</p>
          <p class="mt-5 text-base leading-7 text-white/64">{item.duration}</p>
        </article>
      ))}
    </div>

    <div class="mt-8 overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.05] p-8 shadow-[0_24px_70px_rgba(2,6,10,0.24)] backdrop-blur-xl">
      <p class="text-xs uppercase tracking-[0.24em] text-[#dcc89f]/78">Recommandation de direction</p>
      <p class="mt-4 max-w-4xl font-['Cormorant_Garamond'] text-3xl leading-tight text-white sm:text-[2.4rem]">
        Positionnement visuel recommandé : sobre, premium, institutionnel, très orienté image, avec une touche technologique légère — sans tomber dans un rendu startup générique.
      </p>
    </div>
  </div>
</section>
