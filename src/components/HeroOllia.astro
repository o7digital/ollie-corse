<script>
  const heroRoot = document.querySelector('#hero-ollia');

  if (heroRoot) {
    const languageToggle = heroRoot.querySelector('[data-lang-toggle]');
    const translatableNodes = heroRoot.querySelectorAll('[data-i18n]');

    const translations = {
      fr: {
        mockup_badge: 'Mockup conceptuel — Ollia® Corsica',
        destination_badge: 'Destination digitale premium',
        hero_title: 'Une plateforme premium pour découvrir, réserver et valoriser la Corse.',
        hero_description:
          'Un écosystème Web + Mobile pensé pour le grand public, les partenaires institutionnels, les producteurs et les acteurs touristiques, avec réservations, paiements, gamification, QR codes, géolocalisation et back-offices métiers.',
        cta_user_journey: 'Voir le parcours utilisateur',
        cta_backoffice: 'Explorer le back-office',
        public_home_badge: 'Accueil public',
        discover_title: 'Découvrir la Corse vivante',
        editorial_badge: 'Territoire éditorial',
        territory_title: 'Territoires, artisans, expériences',
        territory_description:
          'Une entrée premium où le récit du territoire rencontre la réservation, le parcours mobile, les producteurs et les expériences à forte valeur émotionnelle.',
        territory_chip_1: 'Filières corses',
        territory_chip_2: 'Expériences premium',
        territory_chip_3: 'Réservation instantanée',
        map_badge: 'Carte interactive',
        map_title: 'Producteurs géolocalisés',
        poi_count: '128 points d’intérêt',
        mobile_badge: 'Expérience mobile',
        mobile_title: 'QR, badges & défis',
        mobile_description:
          'Parcours guidés, scans QR, récompenses et contenus exclusifs activés par la géolocalisation.',
        payments_badge: 'Paiements & réservations',
        payments_title: 'Tunnel premium multi-fournisseurs',
        secure_badge: 'Sécurisé',
        payment_card_1: 'Réservation atelier',
        payment_card_2: 'Wallets & CB',
        payment_card_3: 'Reversement auto'
      },
      en: {
        mockup_badge: 'Concept mockup — Ollia® Corsica',
        destination_badge: 'Premium digital destination',
        hero_title: 'A premium platform to discover, book, and elevate Corsica.',
        hero_description:
          'A Web + Mobile ecosystem designed for the public, institutional partners, producers, and tourism stakeholders, with bookings, payments, gamification, QR codes, geolocation, and business back offices.',
        cta_user_journey: 'View user journey',
        cta_backoffice: 'Explore back office',
        public_home_badge: 'Public home',
        discover_title: 'Discover living Corsica',
        editorial_badge: 'Editorial territory',
        territory_title: 'Territories, artisans, experiences',
        territory_description:
          'A premium gateway where storytelling meets booking, mobile journeys, local producers, and high-emotion experiences.',
        territory_chip_1: 'Corsican sectors',
        territory_chip_2: 'Premium experiences',
        territory_chip_3: 'Instant booking',
        map_badge: 'Interactive map',
        map_title: 'Geolocated producers',
        poi_count: '128 points of interest',
        mobile_badge: 'Mobile experience',
        mobile_title: 'QR, badges & challenges',
        mobile_description:
          'Guided routes, QR scans, rewards, and exclusive content activated by geolocation.',
        payments_badge: 'Payments & bookings',
        payments_title: 'Premium multi-vendor checkout',
        secure_badge: 'Secured',
        payment_card_1: 'Workshop booking',
        payment_card_2: 'Wallets & cards',
        payment_card_3: 'Auto payout',
        floating_mobile_badge: 'Mobile app',
        floating_mobile_title: 'Discovery journey',
        floating_mobile_description:
          'Challenges, routes, badges, and QR scans of Corsican craftsmanship across the territory.'
      }
    };

    const updateLanguage = (lang) => {
      const locale = lang === 'en' ? 'en' : 'fr';
      heroRoot.setAttribute('data-lang', locale);

      translatableNodes.forEach((node) => {
        const key = node.getAttribute('data-i18n');
        const nextText = key ? translations[locale][key] : null;

        if (nextText) {
          node.textContent = nextText;
        }
      });

      if (languageToggle) {
        const nextLabel = locale === 'fr' ? 'Passer en anglais' : 'Switch to French';
        languageToggle.textContent = locale === 'fr' ? 'FR / EN' : 'EN / FR';
        languageToggle.setAttribute('aria-label', nextLabel);
        languageToggle.setAttribute('title', nextLabel);
      }
    };

    const savedLanguage = window.localStorage.getItem('ollia-lang');
    updateLanguage(savedLanguage === 'en' ? 'en' : 'fr');

    languageToggle?.addEventListener('click', () => {
      const currentLanguage = heroRoot.getAttribute('data-lang') === 'en' ? 'en' : 'fr';
      const nextLanguage = currentLanguage === 'fr' ? 'en' : 'fr';

      updateLanguage(nextLanguage);
      window.localStorage.setItem('ollia-lang', nextLanguage);
    });
  }
</script>
